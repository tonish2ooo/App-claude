# Supabase — laisser vide pour fonctionner en localStorage (mode hors-ligne / démo).
# Renseigner ces valeurs (Project Settings → API) pour activer la persistance cloud.
# Ne jamais committer de vraies clés : copier ce fichier en `.env.local`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GoCardless Bank Account Data (agrégation bancaire PSD2).
# Laisser vide pour rester en mode démonstration (données fictives, aucune banque réelle).
# Créer un secret sur https://bankaccountdata.gocardless.com/ → User Secrets.
# Variables SERVEUR uniquement (jamais exposées au client) : ne pas préfixer par NEXT_PUBLIC_.
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
